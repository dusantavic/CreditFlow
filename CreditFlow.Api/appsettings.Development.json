// Development overrides only — merged on top of appsettings.json when
// ASPNETCORE_ENVIRONMENT=Development. No connection string here on
// purpose: it's supplied via User Secrets (dotnet user-secrets set),
// which live outside the repo and are never committed to Git.
{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
